---
# Promtail configuration for Windows — managed by Ansible (promtail_windows role)
# Host: {{ inventory_hostname }} | Generated: {{ ansible_date_time.iso8601 }}

server:
  http_listen_port: {{ promtail_port }}
  grpc_listen_port: 0
  log_level: info

positions:
  filename: {{ promtail_positions_file }}
  sync_period: 10s

clients:
  - url: {{ loki_url }}/loki/api/v1/push
    tenant_id: ""
    batchwait: 1s
    batchsize: 102400
    timeout: 10s
    backoff_config:
      min_period: 500ms
      max_period: 5m
      max_retries: 10
    external_labels:
      host: {{ inventory_hostname }}
      os: windows
      environment: production

scrape_configs:

{% for event_log in promtail_windows_event_logs %}
  # ── Windows Event Log: {{ event_log.name }} ──────────────────────────────
  - job_name: windows-event-{{ event_log.name | lower }}
    windows_events:
      use_incoming_timestamp: false
      bookmark_path: {{ event_log.bookmark }}
      eventlog_name: {{ event_log.name }}
      xpath_query: '*'
      labels:
        job: windows-event-log
        host: {{ inventory_hostname }}
        log_channel: {{ event_log.name | lower }}
    pipeline_stages:
      - json:
          expressions:
            level: levelText
            channel: channel
            provider: providerName
            event_id: eventId
            message: message
      - labels:
          level:
          channel:
          provider:
      - match:
          selector: '{log_channel="security"}'
          stages:
            - regex:
                expression: 'Account Name:\s+(?P<account>\S+)'
            - labels:
                account:

{% endfor %}

{% if promtail_collect_iis %}
  # ── IIS Access Logs ────────────────────────────────────────────────────────
  - job_name: iis-access-logs
    static_configs:
      - targets:
          - localhost
        labels:
          job: iis
          host: {{ inventory_hostname }}
          log_type: access
          __path__: {{ promtail_iis_log_path }}
    pipeline_stages:
      - regex:
          expression: >-
            ^(?P<date>\d{4}-\d{2}-\d{2})\s+(?P<time>\d{2}:\d{2}:\d{2})\s+
            (?P<server_ip>\S+)\s+(?P<method>\S+)\s+(?P<uri_stem>\S+)\s+
            (?P<uri_query>\S+)\s+(?P<server_port>\d+)\s+(?P<username>\S+)\s+
            (?P<client_ip>\S+)\s+(?P<user_agent>\S+)\s+(?P<referer>\S+)\s+
            (?P<status>\d+)\s+(?P<substatus>\d+)\s+(?P<win32_status>\d+)\s+
            (?P<time_taken>\d+)
      - labels:
          method:
          status:
          uri_stem:
      - timestamp:
          source: date
          format: "2006-01-02"
          location: UTC
      - match:
          selector: '{status=~"[45].."}'
          stages:
            - labels:
                level: error
      - drop:
          expression: '^\s*#'
{% endif %}
